{
  "appId": "com.tenthtone.tenthTone",
  "appName": "Tenth Tone",
  "webDir": "web",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "iosScheme": "tenthtone",
    "cleartext": false
  },
  "ios": {
    "contentInset": "always",
    "scheme": "Tenth Tone",
    "limitsNavigationsToAppBoundDomains": false,
    "preferredContentMode": "mobile",
    "scrollEnabled": true,
    "backgroundColor": "#000000"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#6c2bd9",
      "androidSplashResourceName": "splash",
      "iosSpinnerStyle": "small",
      "spinnerColor": "#ffffff"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#000000",
      "overlaysWebView": true
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "resizeOnFullScreen": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
