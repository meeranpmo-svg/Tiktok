<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Distribution method: app-store for TestFlight/App Store, ad-hoc for internal testing -->
    <key>method</key>
    <string>app-store</string>

    <!-- Replace with your actual Apple Developer Team ID (found in App Store Connect → Membership) -->
    <key>teamID</key>
    <string>YOUR_TEAM_ID_HERE</string>

    <!-- Use App Store Connect API for signing — no manual certs/profiles needed -->
    <key>signingStyle</key>
    <string>automatic</string>

    <!-- Strip Swift symbols to reduce binary size -->
    <key>stripSwiftSymbols</key>
    <true/>

    <!-- Upload symbols for crash reporting -->
    <key>uploadSymbols</key>
    <true/>

    <!-- Include bitcode? No — Apple deprecated it in Xcode 14 -->
    <key>compileBitcode</key>
    <false/>

    <!-- Distribution certificate type -->
    <key>destination</key>
    <string>export</string>
</dict>
</plist>
